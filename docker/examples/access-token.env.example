# Do not commit real tokens.
SCUBAGOGGLES_ACCESS_TOKEN=ya29.example-token
SCUBAGOGGLES_CUSTOMER_ID=my_customer
SCUBAGOGGLES_OUTPUT_PATH=/output

# Optional: comma- or space-separated baseline short names.
# SCUBAGOGGLES_BASELINES=gmail,drive,groups

# Optional: merge a mounted config before the token-only runtime overrides.
# SCUBAGOGGLES_CONFIG=/config/scubagoggles.yaml
